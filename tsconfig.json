{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["cli/**/*.ts", "core/**/*.ts", "db/**/*.ts", "payments/**/*.ts", "providers/**/*.ts"]
}
